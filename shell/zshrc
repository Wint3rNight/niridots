  echo "               |                         |     |       |"
  echo "  .            |   [ ]   [ ]   [ ]   [ ] |     |  [ ]  |          ."
  echo "               |                         |     |       |"
  echo "               |   [ ]   [ ]   [ ]   [ ] |     |  [ ]  |"
  echo "        _______|_________________________|_____|_______|_______"
