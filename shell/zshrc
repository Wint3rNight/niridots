export ELECTRON_OZONE_PLATFORM_HINT=wayland

# Auto-attach to zellij session
if [[ -z "$ZELLIJ" ]]; then
    zellij attach -c
fi
export PATH="$(npm config get prefix)/bin:$PATH"
